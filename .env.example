# ManyRows self-host config. Copy to .env, edit, then `docker compose up -d`.
# Anything left commented uses the in-binary default.

# ---------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------

# Sender address for outbound mail (sign-in, password reset, magic
# links). Required — the server refuses to send when this is empty
# and logs an error. Use an address on your own domain so the SMTP
# provider's DKIM/SPF checks pass.
MANYROWS_FROM_EMAIL=no-reply@example.com

# Brand name substituted into admin-facing email subjects and bodies
# ("Your <brand> verification code", "You've been invited to … on
# <brand>"). End-user emails for the apps you host use the per-app
# name and are untouched by this. Defaults to "ManyRows" when unset.
# MANYROWS_BRAND_NAME=ManyRows

# Prometheus metrics are exposed at /metrics (HTTP request rate/latency,
# DB pool saturation, Go runtime + build info). Liveness is /livez (process
# up) and readiness is /readyz (database reachable). Leave the token unset to
# serve /metrics openly (restrict it at your reverse proxy / private network);
# set it to require `Authorization: Bearer <token>` on every scrape.
# MANYROWS_METRICS_TOKEN=

# Pre-claim the super-admin slot before exposing the install. When
# set, the first /admin/register call only succeeds for THIS exact
# email — random scanners hitting your install can't take the slot,
# closing the "claim it before exposing" race documented in the
# README. Leave unset to keep the legacy "first registrant wins"
# behaviour. Changing this value after a different email already
# registered is a no-op (logged at boot).
# MANYROWS_SUPER_ADMIN_EMAIL=ops@yourcompany.com

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------

POSTGRES_USER=manyrows
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=manyrows

# Override which schema ManyRows tables land in. Defaults to "manyrowsauth"
# so the install coexists with whatever else you might add to the DB.
# Installs created before this rename used "manyrows"; on first boot the
# app renames that schema to "manyrowsauth" in place (data preserved), so
# no action is needed. Two exceptions: if you pin MANYROWS_DB_SCHEMA=manyrows
# below it stays as-is, and if you run with MANYROWS_DB_SKIP_MIGRATIONS=true
# you must rename it yourself (ALTER SCHEMA manyrows RENAME TO manyrowsauth).
# MANYROWS_DB_SCHEMA=manyrowsauth

# ---------------------------------------------------------------------
# Public URL — used for JWT iss claims and email links.
# Pinned automatically on the first /admin/register if you leave this
# blank; set explicitly if you're behind a known reverse proxy.
# ---------------------------------------------------------------------

# MANYROWS_BASE_URL=https://auth.yourdomain.com

# ---------------------------------------------------------------------
# Outbound SMTP (optional — without this, mail is logged to stdout)
# ---------------------------------------------------------------------

# MANYROWS_SMTP_HOST=smtp.example.com
# MANYROWS_SMTP_PORT=587
# MANYROWS_SMTP_USERNAME=
# MANYROWS_SMTP_PASSWORD=

# ---------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------

# Turnstile bot challenge — off by default. Set to true and provide
# both keys (or run in dev mode for the test keys) to enable.
# MANYROWS_TURNSTILE_ENABLED=false
# MANYROWS_TURNSTILE_SITE_KEY=
# MANYROWS_TURNSTILE_SECRET_KEY=

# Host port — change if 8080 is taken on your host. The container
# always listens on 8080 internally; only the host side moves.
# MANYROWS_PORT=8080

# ---------------------------------------------------------------------
# Background janitor
# ---------------------------------------------------------------------
# A goroutine sweeps transient tables (dpop_replay, OTPs, expired
# refresh tokens, OAuth state, etc.) and trims event logs (rate-limit
# attempts, auth_logs) on a schedule. Without it those tables grow
# for the life of the install. Defaults below are sensible — leave
# them blank unless you need to tune.

# Interval between sweeps in minutes (default 60).
# MANYROWS_JANITOR_INTERVAL_MINUTES=60

# Retention for the rate-limit `attempts` table in days (default 7).
# Attempts only matter for the last-few-minutes rate-limit window;
# the rest is forensic value only.
# MANYROWS_ATTEMPTS_RETENTION_DAYS=7

# Retention for the `auth_logs` audit table in days (default 90).
# Bump for longer compliance / forensics trails.
# MANYROWS_AUTH_LOG_RETENTION_DAYS=90

# ---- Server-to-server API ----
# Per-key request budget for the server API (default 1200/min). Each API
# key gets this many requests per minute, with up to a minute of unused
# budget accumulating as burst. Raise it for high-throughput integrations;
# lower it to tighten the blast radius of a leaked key. Over-budget
# requests get HTTP 429 with a Retry-After header.
# MANYROWS_API_RATE_PER_MINUTE=1200

# ---------------------------------------------------------------------
# Secret rotation
# ---------------------------------------------------------------------
# SESSION_AUTH_KEY / SESSION_SECRET_KEY / OTP_PEPPER are auto-generated
# on first boot and stored in the DB when unset; set them explicitly for
# config-as-code installs.
#
# To ROTATE one without breaking anything in flight: set the new value in
# the primary var, put the old value in the matching _PREVIOUS var
# (comma-separated list if rotating again before cleanup), deploy, then
# remove _PREVIOUS after the grace window:
#   session keys -> admin session lifetime (operators re-login otherwise)
#                   plus in-flight TOTP/OAuth sign-in steps (<=10 min)
#   OTP pepper   -> 15 minutes for emailed codes, BUT: MFA backup codes
#                   are hashed under the pepper too and cannot be
#                   re-hashed without their plaintexts — keep the old
#                   pepper listed in OTP_PEPPER_PREVIOUS until users have
#                   regenerated (or used up) backup codes minted before
#                   the rotation.
#
# Client/app-user sessions are NOT affected by any of these (they use the
# JWKS signing keys, rotated from the admin UI).
# MANYROWS_SESSION_AUTH_KEY=
# MANYROWS_SESSION_AUTH_KEY_PREVIOUS=
# MANYROWS_SESSION_SECRET_KEY=
# MANYROWS_SESSION_SECRET_KEY_PREVIOUS=
# MANYROWS_OTP_PEPPER=
# MANYROWS_OTP_PEPPER_PREVIOUS=
